# PostgreSQL
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_db

# JWT
JWT_ACCESS_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_in_production
JWT_ACCESS_EXPIRATION=15
JWT_REFRESH_EXPIRATION=10080

# OAuth Yandex
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret
YANDEX_REDIRECT_URI=http://localhost:4200/auth/oauth/yandex/callback